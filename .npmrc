# Configuración de NPM para Arquitecto de Proyectos

# Versión de Node.js mínima
engine-strict=true

# Usar lock files
save-exact=false

# Configuración de auditoría
audit-level=moderate

# Configuración de git
git-tag-version=true
message=chore(release): %s

# Use CI-safe install
ci-strict=true

# Usar exact versions en package.json
legacy-peer-deps=false
