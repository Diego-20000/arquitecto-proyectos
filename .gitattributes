# Auto normalization of line endings
* text=auto

# Git attributes for all files

# Explicitly declare text files and normalize line endings to LF
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf

# Config files
.editorconfig text eol=lf
.eslintrc text eol=lf
.prettierrc text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.npmrc text eol=lf
.nvmrc text eol=lf
Makefile text eol=lf
.env.example text eol=lf

# Binary files (don't touch these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
