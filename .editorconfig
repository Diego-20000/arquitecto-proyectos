root = true

# Todos los archivos
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Archivos JavaScript
[*.{js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 100
quote_type = double
spaces_around_operators = true

# Archivos JSON
[*.{json,jsonc}]
indent_size = 2
insert_final_newline = true

# Archivos JSON5
[*.json5]
quote_type = single
indent_size = 2

# Archivos TypeScript
[*.{ts,tsx}]
indent_size = 2
max_line_length = 100

# Archivos CSS/SCSS/LESS
[*.{css,scss,less}]
indent_size = 2
max_line_length = off

# Archivos HTML
[*.html]
indent_size = 2
max_line_length = off

# Archivos Markdown
[*.md]
indent_size = 2
max_line_length = off
trim_trailing_whitespace = false

# Archivos YAML
[*.{yml,yaml}]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
indent_size = 4

# Archivos Bash
[*.{bash,sh}]
indent_size = 2
end_of_line = lf

# Archivos de configuración
[.{editorconfig,eslintrc,prettierrc,gitignore}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
